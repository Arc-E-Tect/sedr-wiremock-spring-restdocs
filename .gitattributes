# Auto-detect line endings and normalize them
* text=auto

# Force Unix line endings for shell scripts and executables
*.sh text eol=lf
gradlew text eol=lf

# Keep Windows batch files and PowerShell scripts with CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files — leave untouched
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
