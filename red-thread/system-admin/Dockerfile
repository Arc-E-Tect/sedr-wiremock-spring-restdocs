# Runtime image for system-admin microservice
# The bootJar is pre-built by ./gradlew :system-admin:bootJar and must be present
# at system-admin/build/libs/ before this image is built (build context: red-thread/).
FROM eclipse-temurin:21-jre
WORKDIR /app

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Create a non-root user
RUN groupadd -r iff && useradd -r -g iff iff

# Copy the pre-built jar (produced by ./gradlew :system-admin:bootJar)
COPY system-admin/build/libs/system-admin-*.jar app.jar

# Copy the keystore (generated by setup-test-env.sh before Docker build)
COPY system-admin/src/testSystemCommon/resources/ssl/keystore.p12 keystore.p12

# Change ownership
RUN chown -R iff:iff /app

# Switch to non-root user
USER iff

# Expose HTTPS port
EXPOSE 8443

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=5 \
  CMD curl -f -k https://localhost:8443/actuator/health || exit 1

# Run the application
ENTRYPOINT ["java", "-jar", "/app/app.jar"]

